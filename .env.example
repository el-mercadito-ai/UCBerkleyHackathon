# ---- The AI Mercadito :: environment template ----
# Copy to .env.local (web) and .env (agents) and fill in.

# Redis (shared memory / pub-sub of the agent economy)
# Local:  redis://localhost:6379
# Upstash (recommended for Vercel): rediss://default:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379

# Anthropic (Claude) — used by agents to generate bids/pitches
ANTHROPIC_API_KEY=sk-ant-...

# Sentry — the "nervous system" that detects failures
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# The Token Company — payment settlement (placeholder until real API is given)
TOKEN_COMPANY_API_KEY=

# Browserbase / Stagehand — used by the Sai QA agent
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
